# Kibo CSR Assessment - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env    (Linux/Mac)
#   copy .env.example .env  (Windows)
#
# .env is gitignored and will not be committed.

# OpenAI API Key (required for chat with LLM)
# Get your key at: https://platform.openai.com/api-keys
LLM_API_KEY=sk-your-openai-api-key

# Backend API URL (for Vercel/frontend deployment only)
# Set when frontend is deployed separately; e.g. https://your-backend.railway.app/api
# Leave unset for local dev (uses /api proxy)
# VITE_API_URL=https://your-backend.railway.app/api
